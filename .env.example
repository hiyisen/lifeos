# LifeOS Environment Variables
# Copy to .env and fill in values

NUXT_PUBLIC_SITE_NAME=LifeOS
NUXT_DB_PATH=./data/lifeos.db
NUXT_PHOTOS_DIR=./data/photos

# External API keys (optional — manual entry works without them)
TMDB_API_KEY=
IGDB_CLIENT_ID=
IGDB_CLIENT_SECRET=

# Deployment
NUXT_HOST=0.0.0.0
NUXT_PORT=3000
